# ─────────────────────────────────────────────────────────────────
#  FsocietyPK – Frontend Environment Variables
#  Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────────────────────────

# API base URL (proxied in dev via vite.config.ts)
VITE_API_BASE_URL=http://localhost:5000/api

# App metadata
VITE_APP_NAME=FsocietyPK
VITE_APP_DESCRIPTION=Pakistan's Premier CTF Platform

# Feature flags
VITE_ENABLE_REGISTRATION=true
VITE_MAINTENANCE_MODE=false
